RSS_SOURCE_URL=https://blockchain.news/rss
FEED_TITLE=Blockchain News to X
FEED_LINK=https://<username>.github.io/<repo>/feed.xml
FEED_DESCRIPTION=Inspection feed with source articles and extracted body text
X_FEED_TITLE=Blockchain News X Posts
X_FEED_LINK=https://<username>.github.io/<repo>/x-feed.xml
X_FEED_DESCRIPTION=Generated X-ready posts produced from source articles
POST_PREFIX=[News]
POST_SUFFIX=#blockchain
POST_MAX_LENGTH=260
X_POST_PREFIX=
X_POST_SUFFIX=
# 贴文最大字符数（含链接与标签）。默认 260，适配免费 X≈280 上限 + IFTTT 短帖。
# 设为更大（如 1200）且不设下方 STYLE=teaser 时，会自动用「长贴」提示词（偏 Premium 长帖）。
X_POST_MAX_LENGTH=260
# teaser | long | 留空。留空时：X_POST_MAX_LENGTH≤300 为 teaser（高密度短引流贴），否则为 long。
X_POST_STYLE=
# x-feed.xml 只保留最新去重后的 N 条贴文
MAX_X_FEED_ITEMS=3
MAX_NEW_ITEMS=3
MAX_FEED_ITEMS=30
FETCH_ARTICLE_CONTENT=true
ARTICLE_MAX_CHARS=12000
FETCH_TIMEOUT_MS=15000
ENABLE_LLM_POST_GENERATION=true
FORCE_REGENERATE_X_POSTS=false
# OpenAI 示例: https://api.openai.com/v1/chat/completions
# Poe 示例（官方 OpenAI 兼容接口）: https://api.poe.com/v1/chat/completions
# 不要写成 .../v1/chat（缺 completions 会 404，脚本会自动纠正为 .../chat/completions）
# Key 在 https://poe.com/api/keys ；模型名用 Poe 侧名称，如 Claude-Sonnet-4.5、Grok-4
# 也可只写 poe，脚本会展开为 https://api.poe.com/v1/chat/completions
LLM_API_URL=https://api.poe.com/v1/chat/completions
LLM_API_KEY=your_poe_api_key
LLM_MODEL=gpt-5-nano
LLM_TEMPERATURE=0.4
# 短贴（teaser）一般 300–450 即够；长帖请 550–900 并与 X_POST_MAX_LENGTH 同步调高
LLM_MAX_TOKENS=380
LLM_TIMEOUT_MS=30000
# 留空则按 X_POST_STYLE 使用内置 system prompt（teaser=极短爆款钩子，long=多句展开）。
LLM_SYSTEM_PROMPT=
LLM_USER_PROMPT_TEMPLATE=
